# Secret key (sk_test_... en test, sk_live_... en prod) — CONFIDENTIELLE, ne jamais commit
STRIPE_SECRET_KEY=sk_test_xxx

# Webhook signing secret (whsec_...) — créé dans Stripe Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxx
